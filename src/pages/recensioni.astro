---
export const prerender = false;

import Platform from "../layouts/Platform.astro";
import Icona from "../components/Icona.astro";
import { pageSeo } from "../data/seo.js";
import { organizationSchema } from "../data/schema.js";
import { sql } from "../lib/db.js";

// Le recensioni native (per professionista) più recenti, se ci sono
const recensioni = await sql`
  SELECT r.rating, r.text, r.author_name, r.created_at, p.name AS professional_name, p.slug
  FROM reviews r JOIN professionals p ON p.id = r.professional_id
  WHERE r.status = 'published' ORDER BY r.created_at DESC LIMIT 12`;
const dataIt = (d) => new Date(d).toLocaleDateString("it-IT", { month: "long", year: "numeric" });
const [primo] = await sql`
  SELECT name, google_rating FROM professionals
  WHERE status = 'active' AND google_rating IS NOT NULL ORDER BY id LIMIT 1`;
---

<Platform
  title={pageSeo.recensioni.title}
  description={pageSeo.recensioni.description}
  path="/recensioni"
  schemas={[organizationSchema]}
>
  <section class="pf-hero pf-hero-centro">
    <span class="pf-hero-occhiello">Recensioni</span>
    <h1>Recensioni vere, di pazienti veri</h1>
    <p class="sottotitolo">
      Su InfermieriWeb ogni professionista ha le sue recensioni, e può lasciarle solo
      chi ha completato davvero una prenotazione: niente recensioni anonime o comprate.
    </p>
  </section>

  <section class="pf-section">
    <div class="pf-container" style="max-width: 680px;">
      {recensioni.length > 0 ? (
        <div>
          <h2 style="color: var(--iw-navy); margin-bottom: 18px;">Le ultime recensioni verificate</h2>
          {recensioni.map((r) => (
            <div class="pf-panel" style="margin-bottom: 14px;">
              <div class="pf-recensione" style="border: none; padding: 0; margin: 0;">
                <div class="testa">
                  <span class="autore">{r.author_name || "Paziente"} <span class="verificata">✓ verificata</span></span>
                  <span class="data">{dataIt(r.created_at)}</span>
                </div>
                <div class="pf-stars">{"★".repeat(r.rating)}{"☆".repeat(5 - r.rating)}</div>
                {r.text && <p>{r.text}</p>}
                <p class="pf-note" style="margin: 8px 0 0;">per <a href={`/p/${r.slug}`} style="color: var(--iw-primary-deep); font-weight: 700;">{r.professional_name}</a></p>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="pf-panel pf-center">
          <div style="color: #d97706; margin-bottom: 8px;"><Icona nome="stella" size={44} /></div>
          <h2 style="margin: 0 0 6px;">{primo ? `${primo.name} — ${primo.google_rating}` : "I professionisti della rete"}</h2>
          {primo && (() => {
            const v = parseFloat(String(primo.google_rating).replace(",", ".").match(/\d+(\.\d+)?/)?.[0]) || 5;
            const piene = Math.round(v);
            return <div class="pf-stars" style="font-size: 24px;">{"★".repeat(piene)}{"☆".repeat(5 - piene)}</div>;
          })()}
          <p class="pf-note" style="max-width: 520px; margin: 6px auto 0;">Valutazione Google — <strong>non verificata da InfermieriWeb</strong></p>
          <p style="color: var(--iw-slate); max-width: 520px; margin: 12px auto 6px;">
            Le recensioni verificate di InfermieriWeb compariranno qui e sulla scheda di ogni
            professionista: può lasciarle solo chi ha completato una prenotazione tramite il sito.
          </p>
          <a
            class="pf-btn"
            href="https://g.page/r/CblrQcuM1y1GEBM/review"
            target="_blank"
            rel="noopener noreferrer"
            style="margin-top: 12px;"
          >Lascia una recensione su Google</a>
        </div>
      )}

      <div class="pf-panel" style="margin-top: 18px;">
        <h2 style="margin-top: 0;">Come verifichiamo le recensioni</h2>
        <ul class="pf-lista">
          <li>Può lasciare una recensione <strong>solo chi ha completato una prenotazione</strong> tramite InfermieriWeb: dopo la prestazione riceve via email un <strong>link personale e monouso</strong>.</li>
          <li>Non pubblichiamo recensioni anonime né provenienti da altri canali.</li>
          <li>Le recensioni sono del professionista, non della piattaforma: le trovi nella sua scheda.</li>
          <li>Le eventuali valutazioni <strong>«Google»</strong> mostrate su alcune schede provengono da Google e <strong>non sono verificate</strong> con questo metodo: sono segnalate come tali.</li>
        </ul>
      </div>
    </div>
  </section>
</Platform>
