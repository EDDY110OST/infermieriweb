---
import Platform from "../layouts/Platform.astro";
import CandidaturaForm from "../islands/CandidaturaForm.jsx";
import Icona from "../components/Icona.astro";
import { organizationSchema } from "../data/schema.js";

const vantaggi = [
  { icona: "calendario", titolo: "Agenda online dal telefono", testo: "Prenotazioni con i tuoi orari reali, blocchi ferie in un tocco, promemoria automatici ai pazienti." },
  { icona: "stella", titolo: "Recensioni verificate", testo: "Solo chi ha completato una prenotazione può recensirti: la tua reputazione cresce su basi vere." },
  { icona: "posizione", titolo: "Visibilità nella tua zona", testo: "Scheda personale indicizzata su Google e presenza sulla mappa: i pazienti della tua zona ti trovano." },
  { icona: "etichetta", titolo: "Zero commissioni", testo: "I pazienti sono tuoi e il compenso lo incassi tu, per intero. Noi non tocchiamo i tuoi soldi." },
  { icona: "attivita", titolo: "Gratis in fase di lancio", testo: "L'iscrizione è completamente gratuita per i primi professionisti della rete." },
  { icona: "scudo", titolo: "Niente vincoli", testo: "Decidi tu prestazioni, prezzi, zone e disponibilità. Puoi uscire quando vuoi." },
];
---

<Platform
  title="Unisciti alla rete: agenda e visibilità per professionisti sanitari | InfermieriWeb"
  description="Scheda personale, agenda online, prenotazioni e recensioni verificate per infermieri e professionisti sanitari. Gratis in fase di lancio, zero commissioni."
  path="/lavora-con-noi"
  schemas={[organizationSchema]}
>
  <section class="pf-hero" style="padding-bottom: 60px;">
    <h1>Sei un infermiere libero professionista?<br /> La tua agenda, i tuoi pazienti.</h1>
    <p class="sottotitolo">
      InfermieriWeb dà ai professionisti sanitari una scheda personale con recensioni verificate
      e un'agenda di prenotazione online. <strong>Zero commissioni: i pazienti restano tuoi.</strong>
    </p>
    <div class="badges">
      <span>✓ Gratis in fase di lancio</span>
      <span>✓ Zero commissioni</span>
      <span>✓ Verifica albo e attivazione rapida</span>
    </div>
    <p style="position: relative; margin-top: 22px; font-size: 18px;">
      Sei già dei nostri? <a href="/area-professionisti" style="color: #fff; font-weight: 700;">Accedi alla tua agenda →</a>
    </p>
  </section>

  <section class="pf-section pf-center">
    <span class="pf-kicker">Perché entrare</span>
    <h2>Quello che ottieni</h2>
    <div class="pf-steps pf-griglia-3" style="margin-top: 36px;">
      {vantaggi.map((v) => (
        <div class="pf-step">
          <div class="num" style="background: none; color: var(--iw-primary-deep);">{v.icona && <Icona nome={v.icona} size={30} />}</div>
          <h3>{v.titolo}</h3>
          <p>{v.testo}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="pf-section alt">
    <div class="pf-container" style="max-width: 640px;">
      <div class="pf-center">
        <span class="pf-kicker">Candidatura</span>
        <h2>Entra nella rete</h2>
        <p class="pf-sub">
          Compila il modulo: ti ricontattiamo entro pochi giorni per attivare la tua scheda.
          Serve l'iscrizione al tuo albo professionale.
        </p>
      </div>
      <div class="pf-panel">
        <CandidaturaForm client:load />
      </div>

      <div class="pf-panel" style="margin-top: 18px;">
        <h3 style="margin-top: 0;">Vuoi vedere com'è una scheda?</h3>
        <p style="color: var(--iw-slate); margin-bottom: 14px;">
          Questa è la scheda di Eduard, il primo infermiere della rete: foto, prestazioni con i
          prezzi, recensioni e agenda con gli orari reali.
        </p>
        <a class="pf-btn" href="/p/eduard" target="_blank" rel="noopener">Guarda la scheda di Eduard →</a>
      </div>

      <div class="pf-panel" style="margin-top: 18px;">
        <h3 style="margin-top: 0;">Non hai ancora la partita IVA?</h3>
        <p style="color: var(--iw-slate); margin: 0;">
          Puoi registrarti lo stesso: teniamo da parte la tua richiesta e, <strong>appena apri la
          partita IVA</strong>, attiviamo la tua scheda pubblica con le prenotazioni a domicilio.
          Finché non hai la P.IVA il profilo non compare nelle ricerche dei pazienti: è normale,
          la prestazione a domicilio richiede di operare come libero professionista.
        </p>
      </div>

      <div class="pf-panel" style="margin-top: 18px;">
        <h3 style="margin-top: 0;">«Gratis adesso… e poi?»</h3>
        <p style="color: var(--iw-slate); margin: 0;">
          Domanda giusta, risposta chiara: la piattaforma è <strong>gratuita in fase di lancio</strong>.
          Quando introdurremo un abbonamento, chi è già nella rete sarà avvisato <strong>con largo
          anticipo</strong>, potrà scegliere se restare e potrà uscire <strong>senza alcuna penale</strong>.
          E in ogni caso i pazienti sono tuoi: qui non esistono commissioni sulle prestazioni,
          né adesso né dopo.
        </p>
      </div>
    </div>
  </section>
</Platform>
