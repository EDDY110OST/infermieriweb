---
export const prerender = false;
import Platform from "../layouts/Platform.astro";
import ResetPasswordApp from "../islands/ResetPasswordApp.jsx";
---

<Platform
  title="Reimposta la password | InfermieriWeb"
  description="Scegli la nuova password per il tuo accesso professionista."
  path="/reimposta-password"
  robots="noindex, nofollow"
>
  <section class="pf-hero pf-hero-centro" style="padding-bottom: 40px;">
    <span class="pf-hero-occhiello">Area professionisti</span>
    <h1>Reimposta la password</h1>
  </section>

  <section class="pf-section" style="padding-top: 36px;">
    <div class="pf-container" style="max-width: 480px;">
      <div class="pf-panel">
        <ResetPasswordApp client:load />
      </div>
    </div>
  </section>
</Platform>
