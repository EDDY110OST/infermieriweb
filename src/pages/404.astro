---
import Platform from "../layouts/Platform.astro";
---

<Platform
  title="Pagina non trovata | InfermieriWeb"
  description="La pagina che cerchi non esiste o è stata spostata. Cerca un infermiere a domicilio nella tua zona o torna alla home."
  path="/404"
  robots="noindex, follow"
>
  <section class="pf-section pf-center">
    <div class="pf-container" style="max-width: 620px;">
      <span class="pf-kicker">Errore 404</span>
      <h1 style="color: var(--iw-navy); margin-bottom: 12px; font-size: clamp(30px, 4vw, 44px);">Questa pagina non esiste</h1>
      <p style="color: var(--iw-slate); margin-bottom: 28px;">
        Forse è stata spostata o l'indirizzo è sbagliato. Cerca direttamente l'infermiere che ti serve:
      </p>
      <form class="pf-searchbar" action="/cerca" method="get" role="search" style="margin: 0 auto 24px;">
        <input type="search" name="q" placeholder="Città o prestazione" aria-label="Cerca per città o prestazione" />
        <button class="pf-btn" type="submit">Cerca</button>
      </form>
      <p>
        <a class="pf-btn secondario" href="/">Torna alla home</a>
      </p>
    </div>
  </section>
</Platform>
