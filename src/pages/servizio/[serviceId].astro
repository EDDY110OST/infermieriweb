---
import Platform from "../../layouts/Platform.astro";
import ServiceDetailIsland from "../../islands/ServiceDetailIsland.jsx";
import { servicesData } from "../../data/services.js";
import { sql } from "../../lib/db.js";
import { serviceSeo } from "../../data/seo.js";
import { medicalBusinessSchema, breadcrumbSchema, SITE_URL } from "../../data/schema.js";

export const prerender = false;

export function getStaticPathsNonUsato() {
  return Object.keys(servicesData).map((serviceId) => ({ params: { serviceId } }));
}

const { serviceId } = Astro.params;
const service = servicesData[serviceId];
if (!service) return new Response(null, { status: 404 });

// Chi offre DAVVERO questa prestazione: la guida deve portare a una prenotazione,
// non rimandare alla ricerca da capo
const professionisti = await sql`
  SELECT DISTINCT p.slug, p.name, p.city, p.province, p.photo_url, s.id AS service_id, s.price_cents
  FROM professionals p
  JOIN services s ON s.professional_id = p.id AND s.active
  WHERE p.status = 'active' AND lower(s.name) LIKE ${"%" + service.title.split(" ")[0].toLowerCase() + "%"}
  ORDER BY p.name LIMIT 6`;
const euro = (c) => `${(c / 100).toFixed(2).replace(".", ",")} €`;
const seo = serviceSeo(serviceId, service);
const path = `/servizio/${serviceId}`;

const schemas = [
  medicalBusinessSchema,
  breadcrumbSchema([
    { name: "Home", url: `${SITE_URL}/` },
    { name: "Servizi", url: `${SITE_URL}/domicilio` },
    { name: service.title, url: `${SITE_URL}${path}` },
  ]),
];
---

<Platform title={seo.title} description={seo.description} path={path} schemas={schemas}>
  <ServiceDetailIsland pathname={path} params={{ serviceId }} />

  {professionisti.length > 0 && (
    <section class="pf-section alt">
      <div class="pf-container pf-center" style="margin-bottom: 28px;">
        <span class="pf-kicker">Prenota</span>
        <h2>Chi offre questa prestazione</h2>
      </div>
      <div class="pf-pro-list" style="max-width: 780px; margin: 0 auto;">
        {professionisti.map((p) => (
          <div class="pf-pro-card">
            <img class="foto" src={p.photo_url} alt={`Foto di ${p.name}`} loading="lazy" />
            <div class="info">
              <a class="nome" href={`/p/${p.slug}`}>{p.name}</a>
              <div class="zona">📍 {p.city} ({p.province})</div>
              <div class="prezzo">Da {euro(p.price_cents)}</div>
            </div>
            <a class="pf-btn" href={`/p/${p.slug}?servizio=${p.service_id}`}>Prenota</a>
          </div>
        ))}
      </div>
    </section>
  )}
</Platform>
