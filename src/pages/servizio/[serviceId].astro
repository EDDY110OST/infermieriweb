---
export const prerender = false;

import Platform from "../../layouts/Platform.astro";
import Icona from "../../components/Icona.astro";
import { servicesData } from "../../data/services.js";
import { sql } from "../../lib/db.js";
import { serviceSeo } from "../../data/seo.js";
import { organizationSchema, breadcrumbSchema, faqSchema, SITE_URL } from "../../data/schema.js";
import { NOMI_COLLOQUIALI, ARTICOLO_PER_SERVIZIO, faqServizio, matchServizio } from "../../data/servizi-extra.js";
import { nextAvailability } from "../../lib/slots.js";

const { serviceId } = Astro.params;
const service = servicesData[serviceId];
if (!service) return new Response(null, { status: 404 });

// Chi offre DAVVERO questa prestazione: abbinamento esplicito per nome
// (una card per professionista, col SUO servizio giusto e il SUO prezzo)
const righe = await sql`
  SELECT p.id, p.slug, p.name, p.city, p.province, p.photo_url, s.id AS service_id, s.name AS service_name, s.price_cents
  FROM professionals p
  JOIN services s ON s.professional_id = p.id AND s.active
  WHERE p.status = 'active'
  ORDER BY p.name, s.price_cents`;
const perProfessionista = new Map();
for (const r of righe) {
  if (!matchServizio(serviceId, r.service_name)) continue;
  if (!perProfessionista.has(r.id)) perProfessionista.set(r.id, r);
}
const professionisti = [...perProfessionista.values()].slice(0, 6);
const conDisponibilita = await Promise.all(
  professionisti.map(async (p) => ({ ...p, prossima: await nextAvailability(p.id) }))
);

// Articolo del blog abbinato (approfondimento informativo)
const slugArticolo = ARTICOLO_PER_SERVIZIO[serviceId];
const [articolo] = slugArticolo
  ? await sql`SELECT slug, title, excerpt FROM articles WHERE slug = ${slugArticolo} AND status = 'published'`
  : [];

const euro = (c) => `${(c / 100).toFixed(2).replace(".", ",")} €`;
const nomeColloquiale = NOMI_COLLOQUIALI[serviceId] || service.title;
const prezzoDa = professionisti.length
  ? euro(Math.min(...professionisti.map((p) => p.price_cents)))
  : service.price.replace("Da € ", "").trim() + " €";
const faq = faqServizio(nomeColloquiale, prezzoDa);
const seo = serviceSeo(serviceId, service);
const path = `/servizio/${serviceId}`;

const schemas = [
  organizationSchema,
  faqSchema(faq),
  breadcrumbSchema([
    { name: "Home", url: `${SITE_URL}/` },
    { name: "Prestazioni", url: `${SITE_URL}/` },
    { name: nomeColloquiale, url: `${SITE_URL}${path}` },
  ]),
];
---

<Platform title={seo.title} description={seo.description} path={path} schemas={schemas}>
  <section class="pf-hero pf-hero-centro">
    <span class="pf-hero-occhiello">Prestazioni a domicilio</span>
    <h1>{nomeColloquiale}</h1>
    <p class="sottotitolo">{service.shortDescription}. Prezzi chiari, professionisti iscritti all'albo, prenotazione online gratuita.</p>
  </section>

  {professionisti.length > 0 ? (
    <section class="pf-section alt">
      <div class="pf-container pf-center" style="margin-bottom: 28px;">
        <span class="pf-kicker">Prenota</span>
        <h2>Chi offre questa prestazione</h2>
      </div>
      <div class="pf-pro-list" style="max-width: 780px; margin: 0 auto;">
        {conDisponibilita.map((p) => (
          <div class="pf-pro-card">
            <img class="foto" src={p.photo_url} alt={`Foto di ${p.name}`} loading="lazy" />
            <div class="info">
              <a class="nome" href={`/p/${p.slug}`}>{p.name}</a>
              <div class="zona"><Icona nome="posizione" size={15} class="pf-ic-inline" /> {p.city} ({p.province})</div>
              <div class="prezzo">Da {euro(p.price_cents)}</div>
              {p.prossima && <div class="disponibilita"><span class="pf-dot"></span> Prossima disponibilità: <strong>{p.prossima.testo}</strong></div>}
            </div>
            <a class="pf-btn" href={`/p/${p.slug}?servizio=${p.service_id}#prenota`}>Vedi orari e prenota</a>
          </div>
        ))}
      </div>
    </section>
  ) : (
    <section class="pf-section alt pf-center">
      <div class="pf-container" style="max-width: 620px;">
        <h2>Cerca il professionista nella tua zona</h2>
        <p class="pf-sub">La rete cresce una città alla volta: guarda chi copre il tuo comune.</p>
        <a class="pf-btn" href="/cerca">Trova un infermiere</a>
      </div>
    </section>
  )}

  <section class="pf-section" style="padding-top: 40px;">
    <div class="pf-container" style="max-width: 880px;">

      <div class="pf-panel" style="margin-bottom: 18px;">
        <h2 style="margin-top: 0;">Che cos'è e come funziona</h2>
        <p style="color: var(--iw-slate); margin: 0;">{service.fullDescription}</p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 18px; margin-bottom: 18px;">
        <div class="pf-panel">
          <h2 style="margin-top: 0;">Cosa comprende</h2>
          <ul class="pf-lista">
            {service.details.map((d) => <li>{d}</li>)}
          </ul>
        </div>
        <div class="pf-panel">
          <h2 style="margin-top: 0;">Quando è indicata</h2>
          <ul class="pf-lista">
            {service.indications.map((i) => <li>{i}</li>)}
          </ul>
        </div>
      </div>

      <div class="pf-panel" style="margin-bottom: 18px;">
        <h2 style="margin-top: 0;">Quanto costa</h2>
        <p style="color: var(--iw-slate);">
          <strong style="color: var(--iw-navy); font-size: 22px;">da {prezzoDa}</strong> — il prezzo esatto è nella
          scheda di ogni professionista e può variare in base alla complessità e alla distanza.
        </p>
        <p class="pf-note" style="margin: 0;">
          Nessun pagamento online e nessuna carta richiesta: il compenso si regola direttamente
          con l'infermiere, dopo la prestazione.
        </p>
      </div>

      <div class="pf-panel" style="margin-bottom: 18px;">
        <h2 style="margin-top: 0;">Domande frequenti</h2>
        {faq.map((f) => (
          <details class="pf-faq">
            <summary>{f.question}</summary>
            <p>{f.answer}</p>
          </details>
        ))}
      </div>

      {articolo && (
        <div class="pf-panel" style="margin-bottom: 18px; border-left: 4px solid var(--iw-primary);">
          <h2 style="margin-top: 0;">Vuoi approfondire?</h2>
          <p style="color: var(--iw-slate);">
            <a href={`/articoli/${articolo.slug}`} style="color: var(--iw-primary-deep); font-weight: 700;">{articolo.title}</a>
            — {articolo.excerpt}
          </p>
        </div>
      )}
    </div>
  </section>

</Platform>
