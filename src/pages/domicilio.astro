---
import Platform from "../layouts/Platform.astro";
import DomicilioIsland from "../islands/DomicilioIsland.jsx";
import { pageSeo } from "../data/seo.js";
import { medicalBusinessSchema } from "../data/schema.js";
---

<Platform
  title={pageSeo.domicilio.title}
  description={pageSeo.domicilio.description}
  path="/domicilio"
  schemas={[medicalBusinessSchema]}
>
  <DomicilioIsland client:load pathname="/domicilio" />
</Platform>
