---
export const prerender = false;

import Platform from "../../layouts/Platform.astro";
import ArticoliIsland from "../../islands/ArticoliIsland.jsx";
import { pageSeo } from "../../data/seo.js";
import { organizationSchema } from "../../data/schema.js";
import { sql } from "../../lib/db.js";
import { mapArticolo } from "../../lib/blog.js";

const righe = await sql`
  SELECT slug, title, category, excerpt, image, reading_time, published_at, sections, featured
  FROM articles WHERE status = 'published'
  ORDER BY featured DESC, published_at DESC, id DESC`;
const articoli = righe.map(mapArticolo);
---

<Platform
  title={pageSeo.articoli.title}
  description={pageSeo.articoli.description}
  path="/articoli"
  schemas={[organizationSchema]}
>
  <section class="pf-hero pf-hero-centro">
    <span class="pf-hero-occhiello">Blog salute</span>
    <h1>Guide e consigli dei professionisti</h1>
    <p class="sottotitolo">
      Come funziona un ECG a domicilio, quanto costa un infermiere, come gestire un catetere:
      guide chiare, scritte con i professionisti della rete.
    </p>
  </section>

  <ArticoliIsland client:load pathname="/articoli" articles={articoli} />
</Platform>
