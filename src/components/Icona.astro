const tratti = TRATTI[nome] || TRATTI.croce;
---

<svg
  class={`pf-ic ${className}`.trim()}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={tratti}
/>
