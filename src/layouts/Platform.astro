---
import Base from "./Base.astro";
import "../styles/platform.css";
import logo from "../assets/logo.jpeg";
import SocialBar from "../islands/SocialBar.jsx";
import { social } from "../data/social.js";
import { risolviLang, t } from "../i18n/ui.js";

const { title, description, path = "/", ogType, ogImage, ogImageAlt, schemas = [], manifest, robots } = Astro.props;
const current = path.replace(/\/$/, "") || "/";

const lang = risolviLang(Astro);
// link dello switch lingua: stessa pagina, con ?lang= per fissare la scelta
const pathCorrente = Astro.url.pathname;
const linkAltraLingua = `${pathCorrente}?lang=${lang === "it" ? "en" : "it"}`;

// "Dove siamo" nel footer: le città reali della rete, dal database
// (statiche = aggiornate a ogni deploy; SSR = sempre fresche)
const slugifyFooter = (t) => t.toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, "").replace(/['\s]+/g, "-").replace(/[^a-z0-9-]/g, "");
let cittaFooter = [];
try {
  const { sql } = await import("../lib/db.js");
  const zone = await sql`
    SELECT c.city, c.province, c.region, COUNT(*) AS n
    FROM coverage_areas c JOIN professionals p ON p.id = c.professional_id AND p.status = 'active'
    GROUP BY 1, 2, 3 ORDER BY n DESC, c.city LIMIT 6`;
  cittaFooter = zone.map((z) => ({
    city: z.city,
    href: `/professionisti/${slugifyFooter(z.region)}/${slugifyFooter(z.province)}/${slugifyFooter(z.city)}`,
  }));
} catch { /* footer senza città se il DB non risponde */ }
// Menu potato secondo la revisione di Eduard (15/7): due percorsi chiari,
// paziente e professionista. Zone e Chi siamo vivono nel footer.
// Menu minimale (richiesta soci 16/7): "Come funziona" vive nella home,
// "Per i professionisti" si raggiunge dal bottone "Voglio la mia scheda" in fondo alla home
const nav = [
  { href: "/cerca", label: t(lang, "nav.trova") },
  { href: "/come-funziona", label: t(lang, "nav.comeFunziona") },
  { href: "/domicilio", label: t(lang, "nav.prestazioni") },
  { href: "/articoli", label: t(lang, "nav.blog") },
  { href: "/area-professionisti", label: t(lang, "nav.area"), spento: true },
];
---

<Base {title} {description} {path} {ogType} {ogImage} {ogImageAlt} {schemas} {manifest} {robots} {lang}>
  <div class="pf">
    <header class="pf-header">
      <div class="pf-header-inner">
        <a href="/" class="pf-logo" aria-label="InfermieriWeb - Home">
          <img src={logo.src} alt="InfermieriWeb.it" width="982" height="265" />
        </a>
        <button class="pf-burger" aria-label="Apri il menu" aria-expanded="false" aria-controls="pf-nav">
          <span></span><span></span><span></span>
        </button>
        <nav class="pf-nav" id="pf-nav" aria-label="Menu principale">
          {nav.map((item) => (
            <a href={item.href} class={item.spento ? "pf-nav-spento" : undefined} aria-current={current === item.href ? "page" : undefined}>{item.label}</a>
          ))}
          <a class="pf-cta" href="/cerca">{t(lang, "cta.prenota")}</a>
          <a class="pf-cta pf-cta-navy" href="/richiedi-informazioni" aria-current={current === "/richiedi-informazioni" ? "page" : undefined}>{t(lang, "cta.richiediInfo")}</a>
          <a class="pf-lang" href={linkAltraLingua} rel="nofollow" title={t(lang, "lang.switchTo")} aria-label={t(lang, "lang.switchTo")}>
            <strong>{lang === "it" ? "IT" : "EN"}</strong><span> · {lang === "it" ? "EN" : "IT"}</span>
          </a>
          <SocialBar links={social} variant="header" size={19} />
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="pf-footer">
      <div class="pf-footer-grid">
        <div>
          <h4>InfermieriWeb.it</h4>
          <p style="font-size:14.5px; margin:0; max-width:280px;">{t(lang, "footer.tagline")}</p>
        </div>
        <div>
          <h4>{t(lang, "footer.pazienti")}</h4>
          <a href="/cerca">{t(lang, "footer.trovaPro")}</a>
          <a href="/come-funziona">{t(lang, "nav.comeFunziona")}</a>
          <a href="/domicilio">{t(lang, "footer.tutteProt")}</a>
          <a href="/professionisti">{t(lang, "footer.zone")}</a>
          <a href="/articoli">{t(lang, "footer.blogSalute")}</a>
          <a href="/prenotazione">{t(lang, "footer.gestisci")}</a>
          <a href="/le-mie-prenotazioni">{t(lang, "footer.miePren")}</a>
        </div>
        <div>
          <h4>{t(lang, "footer.professionisti")}</h4>
          <a href="/per-i-professionisti">{t(lang, "footer.perche")}</a>
          <a href="/lavora-con-noi">{t(lang, "footer.unisciti")}</a>
          <a href="/area-professionisti">{t(lang, "footer.areaPro")}</a>
          <a href="/per-le-strutture">{t(lang, "footer.strutture")}</a>
        </div>
        <div>
          <h4>{t(lang, "footer.doveSiamo")}</h4>
          {cittaFooter.map((c) => (
            <a href={c.href}>{t(lang, "footer.infermiereA")} {c.city}</a>
          ))}
          <a href="/professionisti">{t(lang, "footer.tutteZone")}</a>
        </div>
        <div>
          <h4>{t(lang, "footer.info")}</h4>
          <a href="/chi-siamo">{t(lang, "footer.chiSiamo")}</a>
          <a href="/recensioni">{t(lang, "footer.recensioni")}</a>
          <a href="/contatti">{t(lang, "footer.contatti")}</a>
          <a href="/privacy">{t(lang, "footer.privacy")}</a>
        </div>
      </div>
      <div class="legal">
        © 2026 InfermieriWeb.it — {t(lang, "footer.legal")}
      </div>
    </footer>
  </div>

  <script is:inline>
    (function () {
      var burger = document.querySelector(".pf-burger");
      var nav = document.getElementById("pf-nav");
      if (burger && nav) {
        burger.addEventListener("click", function () {
          var open = nav.classList.toggle("open");
          burger.setAttribute("aria-expanded", open ? "true" : "false");
        });
      }
    })();
  </script>
</Base>
