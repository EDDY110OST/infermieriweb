---
import Base from "./Base.astro";
import "../styles/platform.css";
import logo from "../assets/logo.jpeg";

const { title, description, path = "/", ogType, ogImage, ogImageAlt, schemas = [], manifest, robots } = Astro.props;
const current = path.replace(/\/$/, "") || "/";
const nav = [
  { href: "/cerca", label: "Trova un infermiere" },
  { href: "/professionisti", label: "Zone coperte" },
  { href: "/#come-funziona", label: "Come funziona" },
  { href: "/le-mie-prenotazioni", label: "La mia prenotazione" },
  { href: "/articoli", label: "Blog salute" },
  { href: "/chi-siamo", label: "Chi siamo" },
  { href: "/lavora-con-noi", label: "Per i professionisti" },
  { href: "/area-professionisti", label: "Area professionisti", spento: true },
];
---

<Base {title} {description} {path} {ogType} {ogImage} {ogImageAlt} {schemas} {manifest} {robots}>
  <div class="pf">
    <header class="pf-header">
      <div class="pf-header-inner">
        <a href="/" class="pf-logo" aria-label="InfermieriWeb - Home">
          <img src={logo.src} alt="InfermieriWeb.it" width="982" height="265" />
        </a>
        <button class="pf-burger" aria-label="Apri il menu" aria-expanded="false" aria-controls="pf-nav">
          <span></span><span></span><span></span>
        </button>
        <nav class="pf-nav" id="pf-nav" aria-label="Menu principale">
          {nav.map((item) => (
            <a href={item.href} class={item.spento ? "pf-nav-spento" : undefined} aria-current={current === item.href ? "page" : undefined}>{item.label}</a>
          ))}
          <a class="pf-cta" href="/cerca">Prenota una prestazione</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="pf-footer">
      <div class="pf-footer-grid">
        <div>
          <h4>InfermieriWeb.it</h4>
          <p style="font-size:14.5px; margin:0; max-width:280px;">
            La rete degli infermieri a domicilio. Partita da Lucca, cresce una
            città alla volta — con professionisti verificati uno per uno.
          </p>
        </div>
        <div>
          <h4>Per i pazienti</h4>
          <a href="/cerca">Trova un professionista</a>
          <a href="/professionisti">Zone coperte</a>
          <a href="/articoli">Blog salute</a>
          <a href="/#come-funziona">Come funziona</a>
          <a href="/prenotazione">Gestisci una prenotazione</a>
          <a href="/le-mie-prenotazioni">Le mie prenotazioni</a>
        </div>
        <div>
          <h4>Per i professionisti</h4>
          <a href="/lavora-con-noi">Unisciti alla piattaforma</a>
          <a href="/area-professionisti">Area professionisti</a>
        </div>
        <div>
          <h4>Dove siamo</h4>
          <a href="/professionisti/toscana/lucca/lucca">Infermiere a Lucca</a>
          <a href="/professionisti/toscana/lucca/capannori">Infermiere a Capannori</a>
          <a href="/professionisti/toscana/lucca/porcari">Infermiere a Porcari</a>
          <a href="/professionisti/toscana/lucca/altopascio">Infermiere ad Altopascio</a>
          <a href="/professionisti/toscana/lucca/montecarlo">Infermiere a Montecarlo</a>
        </div>
        <div>
          <h4>Informazioni</h4>
          <a href="/chi-siamo">Chi siamo</a>
          <a href="/recensioni">Recensioni</a>
          <a href="/contatti">Contatti e assistenza</a>
          <a href="/privacy">Privacy e cookie</a>
        </div>
      </div>
      <div class="legal">
        © 2026 InfermieriWeb.it — La prenotazione è gratuita per il paziente. Il compenso della prestazione
        viene regolato direttamente con il professionista. InfermieriWeb non fornisce prestazioni sanitarie:
        mette in contatto pazienti e professionisti abilitati.
      </div>
    </footer>
  </div>

  <script is:inline>
    (function () {
      var burger = document.querySelector(".pf-burger");
      var nav = document.getElementById("pf-nav");
      if (burger && nav) {
        burger.addEventListener("click", function () {
          var open = nav.classList.toggle("open");
          burger.setAttribute("aria-expanded", open ? "true" : "false");
        });
      }
    })();
  </script>
</Base>
